{
  // Terminal Settings
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.external.windowsExec": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
  "terminal.integrated.defaultProfile.windows": "Windows PowerShell",
  "terminal.integrated.smoothScrolling": true,

  // Editor Settings
  "editor.fontSize": 14,
  "editor.semanticHighlighting.enabled": true,
  "editor.stickyScroll.enabled": false,
  "editor.guides.bracketPairs": "active",
  "editor.renderWhitespace": "none",
  "editor.minimap.enabled": false,
  "editor.wrappingIndent": "indent",
  "editor.folding": false,
  "editor.guides.indentation": false,
  //editor.cursor
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorWidth": 2,
  "editor.cursorBlinking": "smooth",
  //editor.scroll bar
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.smoothScrolling": true,

  // Window Settings
  "window.newWindowProfile": "Default",
  "window.commandCenter": false,
  "window.customTitleBarVisibility": "windowed",
  "window.menuBarVisibility": "compact",
  "window.density.editorTabHeight": "compact",

  // Workbench Settings
  "workbench.productIconTheme": "fluent-icons",
  "workbench.colorTheme": "Slack Theme Dark Mode",
  "workbench.editor.showTabs": "multiple",
  "workbench.activityBar.location": "bottom",
  "workbench.sideBar.location": "right",
  "workbench.layoutControl.enabled": false,
  "workbench.tips.enabled": false,
  "workbench.startupEditor": "none",
  "workbench.editor.empty.hint": "hidden",
  "workbench.tree.indent": 10,
  "files.autoSave": "afterDelay",
  "breadcrumbs.enabled": false,

  // side bar
  "workbench.tree.renderIndentGuides": "none",
  "explorer.compactFolders": false,
  "material-icon-theme.hidesExplorerArrows": true,

  // Extensions Configuration
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "codesnap.containerPadding": "0em",
  "vscode_custom_css.imports": [
    "file:///c:/Users/tahza/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.3/dist/updateHandler.js"
  ],

  // Git Settings
  "git.suggestSmartCommit": false,
  "git.openRepositoryInParentFolders": "always",

  // Spell Check Settings
  "cSpell.userWords": [
    "codesnap",
    "highlightedyank",
    "hlsearch",
    "papangkorn",
    "pitjawong",
    "tabnine",
    "whichkey"
  ],
  "cSpell.customDictionaries": {
    "custom-dictionary-user": {
      "name": "custom-dictionary-user",
      "path": "~/.cspell/custom-dictionary-user.txt",
      "addWords": true,
      "scope": "user"
    }
  },
  "cSpell.ignoreRegExpList": ["/[^\\x00-\\x7F]+/"],
  "cSpell.ignoreWords": ["Burapha", "sersit"],

  // custom language setting
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[python]": {
    "editor.renderWhitespace": "all",
    "editor.guides.indentation": true
  },
  "[html]": {
    "editor.guides.indentation": true
  },
  "[php]": {
    "editor.guides.indentation": true
  },

  // LeetCode
  "leetcode.workspaceFolder": "C:\\Users\\tahza\\.leetcode",
  "leetcode.hint.commandShortcut": false,
  "leetcode.hint.configWebviewMarkdown": false,

  // Vim Configuration
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.useCtrlKeys": true,

  // Vim keybinding
  "vim.handleKeys": {
    "<C-s>": false
  },

  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    },
  ],

  "vim.normalModeKeyBindings": [
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
  },
 ],

  // Vim appearance settings
  "editor.cursorSurroundingLines": 10,
  "vim.smartRelativeLine": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "rgba(250, 189, 47, 0.5)",
  "vim.highlightedyank.textColor": "#202020",
  "vim.highlightedyank.duration": 150,

  // statusbar colors
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": ["#171819", "#ffffff"],
  "vim.statusBarColors.insert": ["#2C2E07", "#ffffff"],
  "vim.statusBarColors.visual": ["#005f87", "#ffffff"],
  "vim.statusBarColors.visualblock": ["#005f87", "#ffffff"],
  "vim.statusBarColors.visualline": ["#005f87", "#ffffff"],
  "vim.statusBarColors.commandlineinprogress": ["#8a5929", "#ffffff"],

  "workbench.colorCustomizations": {
    "editor.background": "#00000000",
    "editorCursor.background": "#000000",
    "editorCursor.foreground": "#7e7e7e",
    "editor.selectionBackground": "#005f87",
    "editor.selectionForeground": "#202020",
    "editorGroup.border": "#00000000",
    "editorLineNumber.foreground": "#464646",
    "editorLineNumber.activeForeground": "#c6c6c6",
    "statusBar.background": "#171819",
    "statusBar.noFolderBackground": "#171819",
    "statusBar.debuggingBackground": "#171819",
    "statusBar.debuggingForeground": "#ffffff",
    "scrollbar.shadow": "#00000000",
    "terminal.background": "#272727",
    "terminal.foreground": "#e8dbb6",
    "terminalCursor.background": "#000000",
    "terminalCursor.foreground": "#645c54",
    "terminal.selectionBackground": "#e8dbb6",
    "terminal.selectionForeground": "#000000",
    "terminal.ansiBlack": "#272727",
    "terminal.ansiBlue": "#548386",
    "terminal.ansiCyan": "#739b6e",
    "terminal.ansiGreen": "#979736",
    "terminal.ansiMagenta": "#a66584",
    "terminal.ansiRed": "#bb3629",
    "terminal.ansiWhite": "#a59986",
    "terminal.ansiYellow": "#cd9b3e",
    "terminal.ansiBrightBlack": "#8f8375",
    "terminal.ansiBrightBlue": "#89a498",
    "terminal.ansiBrightCyan": "#98be82",
    "terminal.ansiBrightGreen": "#b8ba46",
    "terminal.ansiBrightMagenta": "#c8899a",
    "terminal.ansiBrightRed": "#e75740",
    "terminal.ansiBrightWhite": "#e8dbb6",
    "terminal.ansiBrightYellow": "#f0bf4f",
    "statusBar.foreground": "#ffffff"
  },

  // which key settings
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ],
  "whichkey.useFullWidthCharacters": true,
  "whichkey.bindingOverrides": [],
  "whichkey.bindings": [
    {
      "key": "/",
      "name": "[/] Fuzzy search in current editor",
      "type": "command",
      "command": "fuzzySearch.activeTextEditor"
    },
    {
      "key": "a",
      "name": "[A]ad editor to harpoon",
      "type": "command",
      "command": "vscode-harpoon.addEditor"
    },
    {
      "key": "e",
      "name": "[E]dit harpoon editors",
      "type": "command",
      "command": "vscode-harpoon.editEditors"
    },
    {
      "key": "f",
      "name": "[F]ormat Document",
      "type": "command",
      "command": "editor.action.formatDocument"
    },
    {
      "key": "T",
      "name": "Open file [T]ree",
      "type": "command",
      "command": "workbench.view.explorer"
    },
    {
      "key": "s",
      "name": "[S]earch",
      "type": "bindings",
      "bindings": [
        {
          "key": "h",
          "name": "[S]earch [H]arpoon Editors",
          "type": "command",
          "command": "vscode-harpoon.editorQuickPick"
        },
        {
          "key": "p",
          "name": "[S]earch Command [P]alette",
          "type": "command",
          "command": "workbench.action.showCommands"
        },
        {
          "key": "f",
          "name": "[S]earch [F]iles",
          "type": "command",
          "command": "workbench.action.quickOpen"
        },
        {
          "key": "k",
          "name": "[S]earch [K]eybindings",
          "type": "command",
          "command": "workbench.action.openGlobalKeybindings"
        },
        {
          "key": "e",
          "name": "[S]earch [E]xtensions",
          "type": "command",
          "command": "workbench.view.extensions"
        },
        {
          "key": ".",
          "name": "[S]earch Recent Files",
          "type": "command",
          "command": "wokbench.action.openRecent"
        }
      ]
    },
    // LSP
    {
      "key": "c",
      "name": "[C]ode",
      "type": "bindings",
      "bindings": [
        {
          "key": "a",
          "name": "[C]ode [A]ctions",
          "type": "command",
          "command": "editor.action.quickFix"
        }
      ]
    },
    {
      "key": "r",
      "name": "[R]un",
      "type": "bindings",
      "bindings": [
        {
          "key": "c",
          "name": "[R]efactor [C]ode",
          "type": "command",
          "command": "editor.action.refactor"
        },
        {
          "key": "n",
          "name": "[R]e[N]ame Symbol",
          "type": "command",
          "command": "editor.action.rename"
        },
        {
          "key": "d",
          "name": "[R]un with [D]ebuging",
          "type": "command",
          "command": "workbench.action.debug.start"
        },
        {
          "key": "r",
          "name": "[R]un Without debugging",
          "type": "command",
          "command": "workbench.action.debug.run"
        }
      ]
    },
    {
      "key": "g",
      "name": "[G]oto",
      "type": "bindings",
      "bindings": [
        {
          "key": "d",
          "name": "[G]oto [D]efinition",
          "type": "command",
          "command": "editor.revealDefinition"
        },
        {
          "key": "r",
          "name": "[G]oto [R]eferences",
          "type": "command",
          "command": "editor.action.goToReferences"
        },
        {
          "key": "I",
          "name": "[G]oto [I]mplementation",
          "type": "command",
          "command": "editor.action.goToImplementation"
        },
        {
          "key": "D",
          "name": "[G]oto [D]eclaration",
          "type": "command",
          "command": "editor.action.revealDeclaration"
        }
      ]
    },
    {
      "key": "D",
      "name": "Jump to Type [D]efinition",
      "type": "command",
      "command": "editor.action.goToTypeDefinition"
    },
    {
      "key": "d",
      "name": "[D]ocument [S]ymbols",
      "type": "bindings",
      "bindings": [
        {
          "key": "s",
          "name": "[D]ocument [S]ymbols",
          "type": "command",
          "command": "workbench.action.gotoSymbol"
        }
      ]
    },

    // quit tab
    {
      "key": "q",
      "name": "[Q]uit tab",
      "command": "workbench.action.closeActiveEditor",
      "when": "editEditorsFocus"
    },

    // change tab
    {
      "key": "w",
      "name": "[W]indow change",
      "type": "bindings",
      "bindings": [
        {
          "key": "l",
          "name": "[W]indow right",
          "type": "command",
          "command": "workbench.action.navigateRight",
          "args": { "to": "right" }
        },
        {
          "key": "h",
          "name": "[W]indow left",
          "type": "command",
          "command": "workbench.action.navigateLeft",
          "args": { "to": "left" }
        },
        {
          "key": "k",
          "name": "[W]indow up",
          "type": "command",
          "command": "workbench.action.navigateUp",
          "args": { "to": "up" }
        },
        {
          "key": "j",
          "name": "[W]indow down",
          "type": "command",
          "command": "workbench.action.navigateDown",
          "args": { "to": "down" }
        }
      ]
      // end change tab
    }
    // end workbench
  ],
  "terminal.integrated.env.osx": {
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.inheritEnv": false,
  "editor.accessibilitySupport": "off",
  "codesnap.backgroundColor": "#000000",
  "workbench.iconTheme": "material-icon-theme",

} // end
